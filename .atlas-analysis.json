  "keyFeatures": [
    "Multi-tenant city hierarchy (Country → Region → City → Zone → POI)",
    "Server-Driven UI (SDUI) with 380+ blocks across 7 surface types",
    "Commerce engine with 12 offer archetypes (products, bookings, subscriptions, auctions, tickets, etc.)",
    "Citizen portal for complaints, permits, transit, and government services",
    "Fleet & logistics management with real-time driver tracking",
    "IoT sensor pipeline (air quality, smart bins, water quality, traffic, parking)",
    "Identity & compliance with Keycloak SSO, Verifiable Credentials, ZATCA e-invoicing",
    "AI-assisted search, content generation, and recommendation engine",
    "12 Expo mobile apps (superapp, driver, merchant, kiosk, TV, watch, car)",
    "Workflow orchestration with Temporal.io for durable cross-system sagas"
  ],
  "publicApiSurface": [
    "POST /api/bff/auth/login",
    "GET /api/bff/auth/session",
    "POST /api/bff/auth/logout",
    "GET /api/bff/booking",
    "POST /api/bff/booking",
