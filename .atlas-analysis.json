    "GET /api/bff/search",
    "GET /api/bff/tenant/config",
    "GET /api/bff/system/health",
    "CityOSClient (TypeScript SDK)",
    "BffClient / CommerceClient / GovernanceClient / HealthcareClient (domain clients)",
    "SduiClient (Server-Driven UI renderer client)",
    "validateSduiPayload() (SDUI protocol utility)"
  ]
