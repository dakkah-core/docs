classDiagram
  direction TB

  class NodeRedFlowManifest ~interface~ {
    +id: string
    +name: string
    +version: string
    +description: string
    +triggers: string[]
    +outputs: string[]
    +dependencies: string[]
    +critical: boolean
  }

  class FlowHealthStatus ~interface~ {
    +flowId: string
    +name: string
    +healthy: boolean
    +deployed: boolean
    -version: string
    -error: string
  }

  class RetryConfig ~interface~ {
    +maxAttempts: number
    +baseDelayMs: number
    +maxDelayMs: number
    +jitterFactor: number
    -onRetry: (attempt: number, error: Error, delayMs: number) = void
    -onExhausted: (attempts: number, lastError: Error) = void
  }

  class TrytonCallOpts ~interface~ {
    +model: string
    +method: string
    +args: unknown[]
    -retryConfig: PartialRetryConfig
  }

  class TrytonCallResult ~interface~ {
    +result: T
    +attempts: number
  }

  class VCSchema ~interface~ {
    +id: string
    +name: string
    +version: string
    +context: string[]
    +credentialSubjectSchema: Recordstring, unknown
  }

  class SchemaRegistrationResult ~interface~ {
    +schemaId: string
    +name: string
    +registered: boolean
    +alreadyExisted: boolean
    -error: string
  }

  class IoTDeviceIdentity ~interface~ {
    +deviceId: string
    +sensorType: string
    -location: {
    lat: number
    lng: number
    /** Altitude in metres above sea level, optional */
    altMetres?: number
  }
    -zoneId: string
    -tenantId: string
  }

  class SensorReading ~interface~ {
    +value: TValue
    -unit: string
    -confidence: number
    -rawValue: number
  }

  class IoTTelemetryEvent ~interface~ {
    -messageId: string
    +measuredAt: string
    -receivedAt: string
    +device: IoTDeviceIdentity
    +readings: Recordstring, SensorReading
    -meta: Recordstring, unknown
  }

  class AirQualityTelemetry ~interface~ {
    +readings: {
    pm25:    SensorReadingnumber  // PM2.5 μg/m³
    pm10:    SensorReadingnumber  // PM10 μg/m³
    co2:     SensorReadingnumber  // CO₂ ppm
    tvoc:    SensorReadingnumber  // TVOC ppb
    humidity?: SensorReadingnumber // %RH
    temp?:   SensorReadingnumber  // °C
  }
  }

  class ParkingTelemetry ~interface~ {
    +readings: {
    occupied: SensorReadingboolean
    vehicleClass?: SensorReading"car" | "truck" | "motorbike" | "unknown"
  }
  }

  class OccupancyTelemetry ~interface~ {
    +readings: {
    count: SensorReadingnumber
    capacity?: SensorReadingnumber
    /** Percentage occupancy [0, 100] — derived from count / capacity */
    occupancyPct?: SensorReadingnumber
  }
  }

  class TrafficFlowTelemetry ~interface~ {
    +readings: {
    vehiclesPerMinute: SensorReadingnumber
    avgSpeedKmh:       SensorReadingnumber
    queueLengthMetres?: SensorReadingnumber
  }
  }

  class KuzzleDocument ~interface~ {
    +_id: string
    +_source: TBody
    +_index: string
    +_collection: string
