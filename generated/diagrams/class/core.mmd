  }

  class KuzzleRealtimeNotification ~interface~ {
    +type: "document" | "user" | "server"
    +action: "create" | "update" | "delete" | "replace" | "publish"
    +collection: string
    +index: string
    +requestId: string
    +timestamp: number
    -result: KuzzleDocumentTBody
  }

  class MQTTBridgeMessage ~interface~ {
    +topic: string
