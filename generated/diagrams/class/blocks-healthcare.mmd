  class HealthcareBlockBase ~interface~ {
    +id: string
    +blockType: string
    -className: string
  }

  class AppointmentBlockProps ~interface~ {
    +blockType: 'appointment'
    -title: string
    +slots: Array{
    time: string
    available: boolean
    practitioner?: string
  }
    -onBook: (time: string) = void
  }

  class PractitionerCardProps ~interface~ {
    +blockType: 'practitioner-card'
    +name: string
    +specialty: string
