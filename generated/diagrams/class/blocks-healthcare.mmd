  }

  class MedicalRecordBlockProps ~interface~ {
    +blockType: 'medical-record'
    +patientName: string
    +records: Array{
    date: string
    type: string
    summary: string
    doctor: string
  }
  }

  class SymptomCheckerBlockProps ~interface~ {
    +blockType: 'symptom-checker'
    -title: string
    +symptoms: string[]
